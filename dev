#!/usr/bin/env bash
# Local dev: starts docker-compose stack + Vite HMR in parallel.
# Usage: ./dev [wp <args>]
set -euo pipefail

THEME_DIR="web/app/themes/jussipress-theme"

# Proxy wp-cli commands into the app container
if [[ "${1:-}" == "wp" ]]; then
  shift
  if ! docker compose ps --status running app | grep -q app; then
    echo "Error: stack is not running. Start it first with ./dev"
    exit 1
  fi
  docker compose exec app wp --allow-root "$@"
  exit $?
fi

cleanup() {
  echo ""
  echo "Stopping..."
  docker compose down
}
trap cleanup EXIT INT TERM

# Ensure .env exists
if [ ! -f .env ]; then
  echo "Error: .env file not found. Copy .env.example and fill in values."
  exit 1
fi

# Build image if it doesn't exist yet
if ! docker image inspect jussipress-ai:local &>/dev/null; then
  echo "Building image for the first time..."
  docker compose build
fi

# Start the stack (app + db) in background
docker compose up -d

echo "Stack is up → http://localhost:8080"
echo "Starting Vite dev server (Ctrl+C to stop all)..."
echo ""

# Run Vite in foreground so Ctrl+C stops everything via the trap
npm --prefix "$THEME_DIR" run dev
