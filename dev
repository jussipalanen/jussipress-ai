Docker Compose:
  up [svc ...]        Start services detached
  down                Stop and remove containers
  stop [svc ...]      Stop without removing
  restart [svc ...]   Restart service(s)
  rebuild [svc ...]   Rebuild image(s) and restart
  logs [svc]          Follow logs (all or specific service)
  ps                  Show container status

Container:
  shell               sh in app container (www-data)
  root-shell          sh in app container (root)

WordPress:
  wp <cmd>            Run WP-CLI   e.g. ./dev.sh wp plugin list

PHP:
  composer <cmd>      Run Composer inside app container
  lint                PHP style check (Pint --test)
  lint-fix            Auto-fix PHP style (Pint)
  analyse             PHP static analysis (PHPStan)
  test                Run Pest tests

Database:
  db                  Open MariaDB CLI
  db-dump             Dump DB to stdout  (> dump.sql to save)
  db-import <file>    Import a SQL file

Theme (runs on host):
  theme-install       npm ci in theme directory
  theme-dev           Start Vite HMR dev server
  theme-build         Build theme assets (production)
  theme-npm <cmd>     Run any npm command in theme directory
  theme-lint          ESLint check (JS)
  theme-lint-fix      ESLint auto-fix (JS)
  theme-format        Prettier write (JS + CSS)
  theme-format-check  Prettier check without writing
  blade-format        Format all Blade templates
  blade-format-check  Check Blade formatting

Misc:
  nuke                Remove all containers + volumes (destructive)
  help                Show this help
EOF
}

# =============================================================
# Entry point — dispatch when executed directly
# =============================================================
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  cmd="${1:-help}"
  shift 2>/dev/null || true
  "$cmd" "$@"
fi
